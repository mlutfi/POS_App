# Application
app.name=POS Backend
app.env=development

# Web Server
web.port=3001
web.prefork=false

# Database
db.host=localhost
db.port=5432
db.user=postgres
db.password=postgres
db.name=pos_db
db.sslmode=disable

# JWT
jwt.secret=your-super-secret-key-change-in-production
jwt.expiration=24

# Log
log.level=debug
log.format=json